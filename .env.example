# 失语症语言康复系统 — 环境变量模板
# 复制此文件为 .env，填入实际值后启动服务
# .env 文件已被 .gitignore 排除，请勿将真实密钥提交到 Git

# ========== Java 后端 (application.properties) ==========

# 阿里云 Qwen API（用于文本补全/翻译）
LLM_API_KEY=

# 百度 OCR API
BAIDU_APP_ID=
BAIDU_API_KEY=
BAIDU_CLIENT_SECRET=

# 讯飞 ASR/TTS API
FLYTEK_APP_ID=
FLYTEK_API_KEY=
FLYTEK_CLIENT_SECRET=

# MongoDB 认证凭据
MONGO_USERNAME=zsb
MONGO_PASSWORD=

# Redis 密码
REDIS_PASSWORD=

# JWT 签名密钥（生产环境请使用随机生成的强密钥，至少 32 字符）
JWT_SECRET=

# CORS 允许的前端域名（生产环境替换，多个用逗号分隔）
# APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://your-domain.com
# APP_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# ========== Python LLM 模块 (LLM/siliconflow.py) ==========

# SiliconFlow API Key（用于 DeepSeek-V3 诊断与修复）
SILICONFLOW_API_KEY=

# LLM 模块路径（默认自动使用脚本所在目录，跨平台部署时可覆盖）
# LLM_PATH=/path/to/LLM/
# BERT_PATH=/path/to/models/bert-base-chinese

# FastAPI 微服务地址（Java 后端通过此 URL 调用 Python LLM 服务）
LLM_SERVICE_URL=http://127.0.0.1:8001
